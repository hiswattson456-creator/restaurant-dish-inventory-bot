<%- include('_head', { title: 'Категории', page: 'categories' }) %>

<div class="page-header">
  <h1 class="page-title"><i data-lucide="tag"></i> Категории посуды</h1>
</div>

<% if (locals.query && query.error === 'has_items') { %>
<div class="alert alert-error">Нельзя удалить категорию, к которой привязаны позиции.</div>
<% } %>

<!-- Форма добавления -->
<div class="card" style="padding:16px 24px">
  <form method="POST" action="/admin/categories/create" class="form-row">
    <div class="form-group" style="flex:0 0 80px">
      <label>Эмодзи</label>
      <input class="form-control" name="emoji" placeholder="📦" maxlength="8">
    </div>
    <div class="form-group">
      <label>Название *</label>
      <input class="form-control" name="name" placeholder="Например: Фарфоровая посуда" required>
    </div>
    <div style="align-self:flex-end">
      <button type="submit" class="btn btn-primary">+ Добавить</button>
    </div>
  </form>
</div>

<div class="card">
  <table>
    <thead>
      <tr>
        <th>Эмодзи</th>
        <th>Название</th>
        <th>Позиций</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      <% categories.forEach(function(cat) { %>
      <tr>
        <td style="font-size:20px"><%= cat.emoji %></td>
        <td><strong><%= cat.name %></strong></td>
        <td><%= cat.itemCount %></td>
        <td>
          <% if (cat.itemCount === 0) { %>
          <form action="/admin/categories/<%= cat.id %>/delete" method="POST" style="display:inline"
                onsubmit="return confirm('Удалить категорию «<%= cat.name %>»?')">
            <button class="btn btn-danger btn-sm"><i data-lucide="trash-2"></i></button>
          </form>
          <% } else { %>
          <span style="color:#aaa;font-size:12px">Есть позиции</span>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('_foot') %>
