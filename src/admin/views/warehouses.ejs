<%- include('_head', { title: 'Склады', page: 'warehouses' }) %>

<div class="page-header">
  <h1 class="page-title"><i data-lucide="warehouse"></i> Склады</h1>
  <button class="btn btn-primary" onclick="openModal('modal-create')">+ Добавить склад</button>
</div>

<div class="card">
  <table>
    <thead>
      <tr>
        <th>Название</th>
        <th>Статус</th>
        <th>Создан</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      <% warehouses.forEach(function(w) { %>
      <tr>
        <td><strong><%= w.name %></strong></td>
        <td>
          <% if (w.is_active) { %>
            <span class="badge badge-green">Активен</span>
          <% } else { %>
            <span class="badge badge-gray">Отключён</span>
          <% } %>
        </td>
        <td><%= new Date(w.created_at).toLocaleDateString('ru-RU') %></td>
        <td class="actions">
          <button class="btn btn-secondary btn-sm" onclick="openModal('modal-rename-<%= w.id %>')"><i data-lucide="pencil"></i></button>
          <form action="/admin/warehouses/<%= w.id %>/toggle" method="POST" style="display:inline">
            <button class="btn btn-secondary btn-sm" title="<%= w.is_active ? 'Деактивировать' : 'Активировать' %>">
              <i data-lucide="<%= w.is_active ? 'eye-off' : 'eye' %>"></i>
            </button>
          </form>
          <form action="/admin/warehouses/<%= w.id %>/delete" method="POST" style="display:inline"
                onsubmit="return confirm(`Удалить склад «<%= w.name %>»? Это удалит все позиции!`)">
            <button class="btn btn-danger btn-sm"><i data-lucide="trash-2"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Модальные окна переименования -->
<% warehouses.forEach(function(w) { %>
<div id="modal-rename-<%= w.id %>" class="modal-overlay">
  <div class="modal">
    <h3>Переименовать склад</h3>
    <form action="/admin/warehouses/<%= w.id %>/rename" method="POST">
      <div class="form-group">
        <label>Название</label>
        <input class="form-control" name="name" value="<%= w.name %>" required>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal('modal-rename-<%= w.id %>')">Отмена</button>
        <button type="submit" class="btn btn-primary">Сохранить</button>
      </div>
    </form>
  </div>
</div>
<% }) %>

<!-- Модальное окно создания -->
<div id="modal-create" class="modal-overlay">
  <div class="modal">
    <h3>Новый склад</h3>
    <form action="/admin/warehouses/create" method="POST">
      <div class="form-group">
        <label>Название</label>
        <input class="form-control" name="name" placeholder="Кухня FO'X посуда" required autofocus>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal('modal-create')">Отмена</button>
        <button type="submit" class="btn btn-primary">Создать</button>
      </div>
    </form>
  </div>
</div>

<%- include('_foot') %>
