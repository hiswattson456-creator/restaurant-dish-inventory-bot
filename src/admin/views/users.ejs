<%- include('_head', { title: 'Пользователи', page: 'users' }) %>

<div class="page-header">
  <h1 class="page-title"><i data-lucide="users"></i> Пользователи бота</h1>
</div>

<div class="card">
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Имя</th>
        <th>Username</th>
        <th>Зарегистрирован</th>
        <th>Статус</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(function(u) { %>
      <tr>
        <td><code><%= u.tg_id %></code></td>
        <td><%= u.tg_name || '—' %></td>
        <td><% if (u.tg_username) { %>@<%= u.tg_username %><% } else { %>—<% } %></td>
        <td><%= new Date(u.created_at).toLocaleString('ru-RU', { dateStyle: 'short', timeStyle: 'short' }) %></td>
        <td>
          <% if (u.is_active) { %>
            <span class="badge badge-green">Активен</span>
          <% } else { %>
            <span class="badge badge-red">Заблокирован</span>
          <% } %>
        </td>
        <td>
          <form action="/admin/users/<%= u.id %>/toggle" method="POST" style="display:inline">
            <button class="btn btn-sm <%= u.is_active ? 'btn-warning' : 'btn-secondary' %>">
              <% if (u.is_active) { %><i data-lucide="ban"></i> Заблокировать<% } else { %><i data-lucide="check-circle"></i> Разблокировать<% } %>
            </button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('_foot') %>
