<%- include('_head', { title: 'Позиции', page: 'items' }) %>

<div class="page-header">
  <h1 class="page-title"><i data-lucide="utensils"></i> Позиции</h1>
  <button class="btn btn-primary" onclick="openModal('modal-create')">+ Добавить позицию</button>
</div>

<!-- Фильтр -->
<div class="card" style="padding:16px 24px">
  <form method="GET" class="form-row">
    <div class="form-group">
      <label>Склад</label>
      <select class="form-control" name="warehouse">
        <option value="">Все склады</option>
        <% warehouses.forEach(function(w) { %>
          <option value="<%= w.id %>" <%= selectedWarehouse == w.id ? 'selected' : '' %>><%= w.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label>Категория</label>
      <select class="form-control" name="category">
        <option value="">Все категории</option>
        <option value="0" <%= selectedCategory === '0' ? 'selected' : '' %>>📦 Без категории</option>
        <% categories.forEach(function(c) { %>
          <option value="<%= c.id %>" <%= selectedCategory == c.id ? 'selected' : '' %>><%= c.emoji %> <%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div style="align-self:flex-end">
      <button type="submit" class="btn btn-secondary">Применить</button>
    </div>
  </form>
</div>

<div class="card">
  <table>
    <thead>
      <tr>
        <th>Фото</th>
        <th>Название</th>
        <th>Склад</th>
        <th>Категория</th>
        <th>Цена</th>
        <th>Остаток</th>
        <th>Статус</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach(function(item) { %>
      <tr>
        <td>
          <% if (item.photo_file_id) { %>
            <span title="Фото есть"><i data-lucide="image"></i></span>
          <% } else { %>
            <span style="color:#ccc">—</span>
          <% } %>
        </td>
        <td><strong><%= item.name %></strong></td>
        <td><%= item.warehouses ? item.warehouses.name : '—' %></td>
        <td>
          <% if (item.item_categories) { %>
            <%= item.item_categories.emoji %> <%= item.item_categories.name %>
          <% } else { %>
            <span style="color:#aaa">—</span>
          <% } %>
        </td>
        <td><%= item.price != null ? item.price + ' ₽' : '—' %></td>
        <td><strong><%= item.quantity %></strong> шт.</td>
        <td>
          <% if (item.is_active) { %>
            <span class="badge badge-green">Активна</span>
          <% } else { %>
            <span class="badge badge-gray">Скрыта</span>
          <% } %>
        </td>
        <td class="actions">
          <button class="btn btn-secondary btn-sm" onclick="openModal('modal-edit-<%= item.id %>')"><i data-lucide="pencil"></i></button>
          <form action="/admin/items/<%= item.id %>/toggle" method="POST" style="display:inline">
            <button class="btn btn-secondary btn-sm"><i data-lucide="<%= item.is_active ? 'eye-off' : 'eye' %>"></i></button>
          </form>
          <form action="/admin/items/<%= item.id %>/delete" method="POST" style="display:inline"
                onsubmit="return confirm('Удалить позицию «<%= item.name %>»?')">
            <button class="btn btn-danger btn-sm"><i data-lucide="trash-2"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Модальные окна редактирования -->
<% items.forEach(function(item) { %>
<div id="modal-edit-<%= item.id %>" class="modal-overlay">
  <div class="modal">
    <h3>Редактировать позицию</h3>
    <form action="/admin/items/<%= item.id %>/edit" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>Название</label>
        <input class="form-control" name="name" value="<%= item.name %>" required>
      </div>
      <div class="form-group">
        <label>Категория</label>
        <select class="form-control" name="category_id">
          <option value="">Без категории</option>
          <% categories.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= item.category_id == c.id ? 'selected' : '' %>><%= c.emoji %> <%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Цена (₽)</label>
          <input class="form-control" name="price" type="number" step="0.01" value="<%= item.price || '' %>">
        </div>
        <div class="form-group">
          <label>Остаток (шт.)</label>
          <input class="form-control" name="quantity" type="number" min="0" value="<%= item.quantity %>">
        </div>
      </div>
      <div class="form-group">
        <label>Фото (необязательно, заменит текущее)</label>
        <input class="form-control" name="photo" type="file" accept="image/*">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal('modal-edit-<%= item.id %>')">Отмена</button>
        <button type="submit" class="btn btn-primary">Сохранить</button>
      </div>
    </form>
  </div>
</div>
<% }) %>

<!-- Модальное окно создания -->
<div id="modal-create" class="modal-overlay">
  <div class="modal">
    <h3>Новая позиция</h3>
    <form action="/admin/items/create" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>Название *</label>
        <input class="form-control" name="name" required>
      </div>
      <div class="form-group">
        <label>Склад *</label>
        <select class="form-control" name="warehouse_id" required>
          <option value="">Выберите склад</option>
          <% warehouses.forEach(function(w) { %>
            <option value="<%= w.id %>"><%= w.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Категория</label>
        <select class="form-control" name="category_id">
          <option value="">Без категории</option>
          <% categories.forEach(function(c) { %>
            <option value="<%= c.id %>"><%= c.emoji %> <%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Цена (₽)</label>
          <input class="form-control" name="price" type="number" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group">
          <label>Количество (шт.)</label>
          <input class="form-control" name="quantity" type="number" min="0" value="0">
        </div>
      </div>
      <div class="form-group">
        <label>Фото</label>
        <input class="form-control" name="photo" type="file" accept="image/*">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal('modal-create')">Отмена</button>
        <button type="submit" class="btn btn-primary">Создать</button>
      </div>
    </form>
  </div>
</div>

<%- include('_foot') %>
